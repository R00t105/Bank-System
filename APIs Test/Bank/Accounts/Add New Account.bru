meta {
  name: Add New Account
  type: http
  seq: 5
}

post {
  url: http://localhost:8080/accounts
  body: json
  auth: inherit
}

body:json {
  {
    "accountNumber": "123456789012",
    "initialBalance": 1000.50,
    "currency": "EGP",
    "accountType": "SAVINGS",
    "customerId": 1
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
